<?xml version="1.0" standalone="yes"?>
<!-- Tree estimation test using age-dependent birth-death PDE model as tree prior.
     Darwin's finches dataset (16 taxa, 1123 sites).
     Strict clock, HKY substitution model, age-dependent PDE birth-death tree prior.
     Linear-exponential age hazard h(a) = (1 + b*a) * exp(-gamma*a). -->
<beast>

	<!-- ntax=16 -->
	<taxa id="taxa">
		<taxon id="AF_110423_C_olivacea"/>
		<taxon id="AF_109015_C_olivacea"/>
		<taxon id="AF_109025_C_olivacea"/>
		<taxon id="AF_109060_C_parvulus"/>
		<taxon id="AF_109018_C_parvulus"/>
		<taxon id="AF_109019_C_parvulus"/>
		<taxon id="AF_109037_G_magnirostris"/>
		<taxon id="AF_109067_G_magnirostris"/>
		<taxon id="AF_109053_G_fortis"/>
		<taxon id="AF_109052_G_fortis"/>
		<taxon id="AF_109035_G_magnirostris"/>
		<taxon id="AF_109028_G_fortis"/>
		<taxon id="AF_109036_G_magnirostris"/>
		<taxon id="AF_109016_G_magnirostris"/>
		<taxon id="AF_109027_G_fortis"/>
		<taxon id="AF_109034_G_magnirostris"/>
	</taxa>

	<!-- ntax=16 nchar=1123 -->
	<alignment id="alignment" dataType="nucleotide">
		<sequence>
			<taxon idref="AF_110423_C_olivacea"/>
			----------TCCCC-GCCCCACATAAAACAGCCCTTACAAAAACCAAACAAAAATACAAACCACAACATTAAACCANTAAAGGAA----CCCTCCCCGTTCTTGTAGCTTATAAAAAGCATGACACT
		</sequence>
		<sequence>
			<taxon idref="AF_109015_C_olivacea"/>
			-------NNTNTCCCCCGCCCCACATAAAACAGCCCTTACAAAAACCAAACAAAAATACAAACCACAACATTAAACCATTAANGGAN----CCCTCCCCGTTCTTGTAGCTTATAAAAAGCATGACACT
		</sequence>
		<sequence>
			<taxon idref="AF_109025_C_olivacea"/>
			ATAGCCAACGTCATACGTCATGCCCCTCCACCAAAAGCCCAAACATTATCTCCAAAACGGACCTCATTCGGCCAACACACCTACCAGGCACATTCTTGCTTCAGGTACCATATAGCCCAAATGCGTCTACCTACAGCCGAGCCGCAAGCGTCACCCAAAGACCCAGGAACTTATCTACTGTACATACCCCTCAACCTCGG-AACGACTACCGTCACAGTACACCTTTGAATTCCCCTAGTCTACTGAATTCGCCCACCTCCTAGGTACAATTCTTCACCAACAGCCTTCAAGCACTCCCAAGCCAGAGGACATGGTTATCTATTGATCGCGCTTCTCACGAGAACCGAGCTACTCAACGTCGAAAGTACCCTACGTTATTGCCCTGCAGGCGCATACATCTCCTAACCTTGCTCTTTTGCGCTATTGGTTGTAACTTCAGGAACATACCTGAC--AATTCTTTCATCAAATAATCAAACCATATATTCCTAGATTGTCCAAACCATTCATCATCAACACTTCCAACTTACTTTCCTCTATATTTTCTGCTAACATAAAACAACAACCAACCATCATCACCACCACATTTTT----------TTCCCC-GCCCCACATAAAACAGCCCTTACAAAAACCAAACAAAAATACAAACCACAACATTAAACCATTAAGGGA-----CCCTCCCCGTTCTTGTAGCTTATAAAAAGCATGACACT
		</sequence>
		<sequence>
			<taxon idref="AF_109060_C_parvulus"/>
			--AACCATTTATCATCAACATTTACAACTTACTTTCCTCTACATTTCCTGCTAACATAAAACAACAACTAACCATCATCACCACCATATTTTTCCTCCCCTTATTCCCCTAACCCACACAAAACAGCCCTTACAAAAACCAAACAAAAATACAAACCATGACACCAAACCACTAAAGGAA---CCCCCCCCCGTTCCTGTAGCTTATAAAAAGCATGACACT
		</sequence>
		<sequence>
			<taxon idref="AF_109018_C_parvulus"/>
			-----CCCCCCCCGTTCTTGTAGCTTATAAAAAGCATGACACT
		</sequence>
		<sequence>
			<taxon idref="AF_109019_C_parvulus"/>
			-----CCCCCCCCGTTCTTGTAGCTTATAAAAAGCATGACACT
		</sequence>
		<sequence>
			<taxon idref="AF_109037_G_magnirostris"/>
			--TTTTCCTCCCCTT-TTCCCCTACCCCACACAAAACAGCCCTTACAAAAACCAAACAAAAATACAAACCATGACACCAAACCACCAAAGGAA--CCCCCCCCCCGTTCTTGTAGCTTATAAAAAGCATGGCACT
		</sequence>
		<sequence>
			<taxon idref="AF_109067_G_magnirostris"/>
			--TTTTCCTCCCCTT-TTCCCCTACCCCACACAAAACAGCCCTTACAAAAACCAAACAAAAATACAAACCATGACACCAAACCACCAAAGGAA--CCCCCCCCCCGTTCTTGTAGCTTATAAAAAGCATGACACT
		</sequence>
		<sequence>
			<taxon idref="AF_109053_G_fortis"/>
			----CCCCCCCCCGTTCTTGTAGCTTATAAAAAGCATGACACT
		</sequence>
		<sequence>
			<taxon idref="AF_109052_G_fortis"/>
			--TTCCCCTACCCCACACAAAACAGCCCTTACAAAAACCAAACAAAAATACAAACCATGACACCAAACCACCAAAGGAA---CCCCCCCCCGTTCTTGTAGCTTATAAAAAGCATGACACT
		</sequence>
		<sequence>
			<taxon idref="AF_109035_G_magnirostris"/>
			---CCCCCCCCCCGTTCTTGTAGCTTATAAAAAGCATGACACT
		</sequence>
		<sequence>
			<taxon idref="AF_109028_G_fortis"/>
			--TTTTCCTCCCCTT-TTCCCCTACCCCACACAAAATAGCCCCTACAAAAACCAAACAAAAATACAAACCATGACACCAAACCACCAAAGGAACCCCCCCCCCCCGTTCTTGTAGCTTATAAAAAGCATGACACT
		</sequence>
		<sequence>
			<taxon idref="AF_109036_G_magnirostris"/>
			--TTTTCCTCCCCTT-TTCCCCTACCCCACACAAAACAGCCCTTACAAAAACCAAACAAAAATACAAACCATAACACCAAACCACCAAAGGAACCCCCCCCCCCCGTTCTTGTAGCTTATAAAAAGCATGACACT
		</sequence>
		<sequence>
			<taxon idref="AF_109016_G_magnirostris"/>
			--TTTTCCTCCCCTT-TTCCCCTACCCCACACAAAACAGCCCTTACAAAAACCAAACAAAAATACAAVCCATGACACCAAACCACCAAAGGAA---CCCCCCCCCGTTCTTGTAGCTTATAAAAAGCATGACACT
		</sequence>
		<sequence>
			<taxon idref="AF_109027_G_fortis"/>
			--TTTTCCTCCCCTT-TTCCCCTACCCCACACAAAACAGCCCTTACAAAAACCAAACAAAAATACAAACCATGACACCAAACCACCAAAGGAA----CCCCCCCCGTTCTTGTAGCTTATAAAAAGCATGACACT
		</sequence>
		<sequence>
			<taxon idref="AF_109034_G_magnirostris"/>
			--TTTTCCTCCCCTT-TTCCCCTACCCCACACAAAACAGCCCTTACAAAAACCAAACAAAAATACAAACCATGACACCAAACCACCAAAGGAA--CCCCCCCCCCGTTCTTGTAGCTTATAAAAAGCATGACACT
		</sequence>
	</alignment>

	<!-- Unique site patterns -->
	<patterns id="patterns">
		<alignment idref="alignment"/>
	</patterns>

	<!-- Initial demographic model for starting tree -->
	<constantSize id="initialDemo" units="substitutions">
		<populationSize>
			<parameter id="initialDemo.popSize" value="100.0"/>
		</populationSize>
	</constantSize>

	<!-- Random starting tree under coalescent -->
	<coalescentTree id="startingTree" rootHeight="0.018">
		<taxa idref="taxa"/>
		<constantSize idref="initialDemo"/>
	</coalescentTree>

	<!-- Tree model -->
	<treeModel id="treeModel">
		<coalescentTree idref="startingTree"/>
		<rootHeight>
			<parameter id="treeModel.rootHeight"/>
		</rootHeight>
		<nodeHeights internalNodes="true">
			<parameter id="treeModel.internalNodeHeights"/>
		</nodeHeights>
		<nodeHeights internalNodes="true" rootNode="true">
			<parameter id="treeModel.allInternalNodeHeights"/>
		</nodeHeights>
	</treeModel>

	<!-- PDE model parameters -->
	<!-- Single epoch: origin time (estimated, must exceed root height) -->
	<parameter id="epochTimes" value="0.1" lower="0.0"/>

	<!-- Scale parameters -->
	<parameter id="birthScale" value="50.0" lower="0.0"/>
	<parameter id="deathScale" value="25.0" lower="0.0"/>

	<!-- Shape parameters [b, gamma] for linear-exponential hazard -->
	<parameter id="birthB" value="0.5" lower="0.0" upper="10.0"/>
	<parameter id="birthGamma" value="0.3"/>
	<compoundParameter id="birthShape">
		<parameter idref="birthB"/>
		<parameter idref="birthGamma"/>
	</compoundParameter>

	<parameter id="deathB" value="0.2" lower="0.0" upper="10.0"/>
	<parameter id="deathGamma" value="0.1"/>
	<compoundParameter id="deathShape">
		<parameter idref="deathB"/>
		<parameter idref="deathGamma"/>
	</compoundParameter>

	<!-- Age-dependent birth-death PDE model -->
	<ageDependentBirthDeathPDEModel id="agePDE" symmetric="true" timeSteps="100" ageSteps="10">
		<treeModel idref="treeModel"/>
		<epochTimes>
			<parameter idref="epochTimes"/>
		</epochTimes>
		<birthScale>
			<parameter idref="birthScale"/>
		</birthScale>
		<birthShape>
			<parameter idref="birthShape"/>
		</birthShape>
		<deathScale>
			<parameter idref="deathScale"/>
		</deathScale>
		<deathShape>
			<parameter idref="deathShape"/>
		</deathShape>
	</ageDependentBirthDeathPDEModel>

	<!-- HKY substitution model -->
	<HKYModel id="hky">
		<frequencies>
			<frequencyModel dataType="nucleotide">
				<frequencies>
					<parameter id="frequencies" value="0.25 0.25 0.25 0.25"/>
				</frequencies>
			</frequencyModel>
		</frequencies>
		<kappa>
			<parameter id="kappa" value="1.0" lower="1.0E-8" upper="Infinity"/>
		</kappa>
	</HKYModel>

	<!-- Site model -->
	<siteModel id="siteModel">
		<substitutionModel>
			<HKYModel idref="hky"/>
		</substitutionModel>
	</siteModel>

	<!-- Tree likelihood (strict clock at rate 1.0 by default) -->
	<treeLikelihood id="treeLikelihood" useAmbiguities="false">
		<patterns idref="patterns"/>
		<treeModel idref="treeModel"/>
		<siteModel idref="siteModel"/>
	</treeLikelihood>

	<!-- Operators -->
	<operators id="operators" optimizationSchedule="log">
		<!-- Tree operators -->
		<subtreeSlide size="0.001" gaussian="true" weight="15">
			<treeModel idref="treeModel"/>
		</subtreeSlide>
		<narrowExchange weight="15">
			<treeModel idref="treeModel"/>
		</narrowExchange>
		<wideExchange weight="3">
			<treeModel idref="treeModel"/>
		</wideExchange>
		<wilsonBalding weight="3">
			<treeModel idref="treeModel"/>
		</wilsonBalding>
		<scaleOperator scaleFactor="0.75" weight="3">
			<parameter idref="treeModel.rootHeight"/>
		</scaleOperator>
		<uniformOperator weight="30">
			<parameter idref="treeModel.internalNodeHeights"/>
		</uniformOperator>

		<!-- PDE model parameter operators -->
		<scaleOperator scaleFactor="0.75" weight="3">
			<parameter idref="epochTimes"/>
		</scaleOperator>
		<scaleOperator scaleFactor="0.5" weight="3">
			<parameter idref="birthScale"/>
		</scaleOperator>
		<scaleOperator scaleFactor="0.5" weight="3">
			<parameter idref="deathScale"/>
		</scaleOperator>
		<randomWalkOperator windowSize="0.1" weight="3">
			<parameter idref="birthB"/>
		</randomWalkOperator>
		<randomWalkOperator windowSize="0.1" weight="3">
			<parameter idref="birthGamma"/>
		</randomWalkOperator>
		<randomWalkOperator windowSize="0.1" weight="3">
			<parameter idref="deathB"/>
		</randomWalkOperator>
		<randomWalkOperator windowSize="0.1" weight="3">
			<parameter idref="deathGamma"/>
		</randomWalkOperator>

		<!-- Substitution model operators -->
		<scaleOperator scaleFactor="0.75" weight="1">
			<parameter idref="kappa"/>
		</scaleOperator>
		<deltaExchange delta="0.01" weight="1">
			<parameter idref="frequencies"/>
		</deltaExchange>
	</operators>

	<!-- MCMC -->
	<mcmc id="mcmc" chainLength="1000000" autoOptimize="true">
		<posterior id="posterior">
			<prior id="prior">
				<!-- Tree prior: age-dependent birth-death PDE model -->
				<ageDependentBirthDeathPDEModel idref="agePDE"/>
				<!-- Priors on PDE model parameters -->
				<logNormalPrior mean="-2.3" stdev="1.0" offset="0.0" meanInRealSpace="false">
					<parameter idref="epochTimes"/>
				</logNormalPrior>
				<logNormalPrior mean="0.0" stdev="1.0" offset="0.0" meanInRealSpace="false">
					<parameter idref="birthScale"/>
				</logNormalPrior>
				<logNormalPrior mean="0.0" stdev="1.0" offset="0.0" meanInRealSpace="false">
					<parameter idref="deathScale"/>
				</logNormalPrior>
				<exponentialPrior mean="1.0" offset="0.0">
					<parameter idref="birthB"/>
				</exponentialPrior>
				<exponentialPrior mean="1.0" offset="0.0">
					<parameter idref="deathB"/>
				</exponentialPrior>
				<normalPrior mean="0.0" stdev="2.0">
					<parameter idref="birthGamma"/>
				</normalPrior>
				<normalPrior mean="0.0" stdev="2.0">
					<parameter idref="deathGamma"/>
				</normalPrior>
				<!-- Prior on substitution model -->
				<oneOnXPrior>
					<parameter idref="kappa"/>
				</oneOnXPrior>
			</prior>
			<likelihood id="likelihood">
				<treeLikelihood idref="treeLikelihood"/>
			</likelihood>
		</posterior>
		<operators idref="operators"/>

		<!-- Screen log -->
		<log logEvery="100000">
			<column label="Posterior" dp="4" width="12">
				<posterior idref="posterior"/>
			</column>
			<column label="Prior" dp="4" width="12">
				<prior idref="prior"/>
			</column>
			<column label="Likelihood" dp="4" width="12">
				<likelihood idref="likelihood"/>
			</column>
			<column label="rootHeight" sf="6" width="12">
				<parameter idref="treeModel.rootHeight"/>
			</column>
			<column label="birthScale" sf="6" width="12">
				<parameter idref="birthScale"/>
			</column>
			<column label="deathScale" sf="6" width="12">
				<parameter idref="deathScale"/>
			</column>
			<column label="originTime" sf="6" width="12">
				<parameter idref="epochTimes"/>
			</column>
		</log>

		<!-- File log -->
		<log id="fileLog" logEvery="1000" fileName="agePDE_treeEstimation.log">
			<posterior idref="posterior"/>
			<prior idref="prior"/>
			<likelihood idref="likelihood"/>
			<parameter idref="treeModel.rootHeight"/>
			<parameter idref="epochTimes"/>
			<parameter idref="birthScale"/>
			<parameter idref="deathScale"/>
			<parameter idref="birthShape"/>
			<parameter idref="deathShape"/>
			<parameter idref="kappa"/>
			<parameter idref="frequencies"/>
			<ageDependentBirthDeathPDEModel idref="agePDE"/>
			<treeLikelihood idref="treeLikelihood"/>
		</log>

		<!-- Tree log -->
		<logTree id="treeFileLog" logEvery="1000" nexusFormat="true" fileName="agePDE_treeEstimation.trees" sortTranslationTable="true">
			<treeModel idref="treeModel"/>
			<posterior idref="posterior"/>
		</logTree>
	</mcmc>

	<report>
		<property name="timer">
			<mcmc idref="mcmc"/>
		</property>
	</report>

</beast>
