<?xml version="1.0" standalone="yes"?>

<beast>

    <taxa id="taxa">
        <taxon id="a"/>
        <taxon id="b"/>
    </taxa>

    <generalDataType id="threeState">
        <state code="A"/>
        <state code="B"/>
        <state code="C"/>
    </generalDataType>

    <alignment id="alignment">
        <generalDataType idref="threeState"/>
        <sequence>
            <taxon idref="a"/>
            A
        </sequence>
        <sequence>
            <taxon idref="b"/>
            C
        </sequence>
    </alignment>

    <patterns id="patterns" from="1" unique="false" strip="false">
        <alignment idref="alignment"/>
    </patterns>

    <newick id="startingTree">(a:0.9,b:0.9);</newick>

    <treeModel id="treeModel">
        <newick idref="startingTree"/>
        <rootHeight>
            <parameter id="treeModel.rootHeight"/>
        </rootHeight>
        <nodeHeights internalNodes="true">
            <parameter id="treeModel.internalNodeHeights"/>
        </nodeHeights>
        <nodeHeights internalNodes="true" rootNode="true">
            <parameter id="treeModel.allInternalNodeHeights"/>
        </nodeHeights>
    </treeModel>

    <frequencyModel id="threeStateFreqModel" normalize="true">
        <generalDataType idref="threeState"/>
        <frequencies>
            <parameter id="threeState.frequencies" value="0.3 0.4 0.3"/>
        </frequencies>
    </frequencyModel>

    <complexSubstitutionModel id="threeStateModel" normalized="false">
        <generalDataType idref="threeState"/>
        <frequencies>
            <frequencyModel idref="threeStateFreqModel"/>
        </frequencies>
        <rates>
            <parameter id="threeStateRates" value="1.0 1.4 2.0 1.7 1.2 2.4"/>
        </rates>
    </complexSubstitutionModel>

    <siteModel id="siteModel">
        <substitutionModel>
            <complexSubstitutionModel idref="threeStateModel"/>
        </substitutionModel>
        <mutationRate>
            <parameter id="siteModel.mu" value="1.0"/>
        </mutationRate>
    </siteModel>

    <arbitraryBranchRates id="reward.branchRates" reciprocal="false" exp="false" centerAtOne="false">
        <rates>
            <parameter id="rewardProportion" value="0.35 0.65" lower="0.0" upper="1.0"/>
        </rates>
        <treeModel idref="treeModel"/>
    </arbitraryBranchRates>

    <rewardsAwareBranchModel id="rewardAwareBranchModel" conditional="false">
        <arbitraryBranchRates idref="reward.branchRates"/>
        <complexSubstitutionModel idref="threeStateModel"/>
        <indicator>
            <parameter id="indicator" value="0.0 0.0"/>
        </indicator>
        <atomIndices>
            <parameter id="atomIndices" value="0.0 2.0"/>
        </atomIndices>
        <rewardRates id="rewardRates.block">
            <fixedValues>
                <parameter id="rewardRatesFixed" value="0.0 1.0"/>
            </fixedValues>
            <varyingValues>
                <parameter id="rewardRatesInternal" value="0.55" lower="0.0" upper="1.0"/>
            </varyingValues>
            <stateIndices>
                <parameter id="rewardRatesMapping" value="0.0 2.0 1.0"/>
            </stateIndices>
        </rewardRates>
    </rewardsAwareBranchModel>

    <treeDataLikelihood id="treeLikelihood" useAmbiguities="false" usePreOrder="true" branchRateDerivative="true">
        <patterns idref="patterns"/>
        <treeModel idref="treeModel"/>
        <siteModel idref="siteModel"/>
        <rewardsAwareBranchModel idref="rewardAwareBranchModel"/>
        <arbitraryBranchRates idref="reward.branchRates"/>
    </treeDataLikelihood>

    <rewardAwareBranchModelRewardRateGradient id="rewardRateGradient"
                                              gradientCheckTolerance="1e-3"
                                              numericStepSize="small">
        <treeDataLikelihood idref="treeLikelihood"/>
        <rewardsAwareBranchModel idref="rewardAwareBranchModel"/>
        <rewardRates idref="rewardRates.block"/>
    </rewardAwareBranchModelRewardRateGradient>

    <cachedReport id="rewardRateGradientReport">
        <rewardAwareBranchModelRewardRateGradient idref="rewardRateGradient"/>
    </cachedReport>

    <report>
        <cachedReport idref="rewardRateGradientReport"/>
    </report>

</beast>
