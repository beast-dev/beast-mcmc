                           timeCount="300"
                           timeStep="0.05"
                           sigmaObs="0.10"
                           grid="irregular"
                           warmup="20"
                           timedIterations="100"
                           perturbEachIteration="true"
                           perturbation="1e-9"
                           perturbIndex="0"/> -->

    <ouTimeSeriesBenchmark id="ou.irregular.gradient"
                           mode="gradient"
                           stateDimension="30"
                           timeCount="300"
                           timeStep="0.05"
                           sigmaObs="0.10"
                           grid="irregular"
                           warmup="20"
                           timedIterations="100"
                           perturbEachIteration="true"
                           perturbation="1e-9"
                           perturbIndex="0"/>

</beast>
