<?xml version="1.0" standalone="yes"?>
<!--
  Sequence simulation + tree inference with age-dependent birth rates.

  Tree simulation (two-epoch, age-dependent birth):
    birthScale = [0.3, 0.18]  (2 epochs)
    deathScale = [0.06, 0.03] (2 epochs)
    birthShape = [5.0, 1.0]   (b=5, gamma=1) — peak hazard ~2.25 at age ~0.8
    deathShape = [0.0, 0.0]   (no age-dependence in death)
    epochTimes = [5.0, 18.0]  (epoch boundary at 5.0, origin at 18.0)
    ~1000 tips

  Sequence simulation:
    HKY, kappa = 4.0, freqs = (0.3, 0.2, 0.2, 0.3)
    Strict clock, rate = 0.01
    Gamma (alpha=0.5, 4 categories) + invariant sites (pInv=0.1)
    1000 sites

  Inference:
    Tree topology and branch lengths estimated
    TABD PDE tree prior (birthScale, deathScale, birthShape estimated)
    Epoch times fixed at true values [5.0, 18.0]
    HKY (kappa estimated), strict clock (rate fixed)
    Gamma + invariant sites (alpha, pInv estimated)
    Estimating: tree, kappa, frequencies, alpha, pInv, birthScale, deathScale, birthShape
-->
<beast>

    <!-- ================================================================== -->
    <!-- Step 1: Simulate tree under two-epoch age-dependent BD              -->
    <!-- ================================================================== -->

    <ageDependentBirthDeathSimulator id="simTree" symmetric="true" seed="9746"
                                     originTime="18.0" minTips="900" maxTips="1100"
                                     maxAttempts="500000" maxLineages="500000">
        <birthScale><parameter value="0.3 0.18"/></birthScale>
        <deathScale><parameter value="0.06 0.03"/></deathScale>
        <birthShape><parameter value="5.0 1.0"/></birthShape>
        <deathShape><parameter value="0.0 0.0"/></deathShape>
        <epochTimes><parameter value="5.0"/></epochTimes>
    </ageDependentBirthDeathSimulator>

    <report>
        Simulated tree:
        <ageDependentBirthDeathSimulator idref="simTree"/>
    </report>

    <treeModel id="simTreeModel">
        <ageDependentBirthDeathSimulator idref="simTree"/>
        <rootHeight>
            <parameter id="simTreeModel.rootHeight"/>
        </rootHeight>
        <nodeHeights internalNodes="true">
            <parameter id="simTreeModel.internalNodeHeights"/>
        </nodeHeights>
        <nodeHeights internalNodes="true" rootNode="true">
            <parameter id="simTreeModel.allInternalNodeHeights"/>
        </nodeHeights>
    </treeModel>

    <!-- ================================================================== -->
    <!-- Step 2: Simulate sequences on the tree                              -->
    <!-- ================================================================== -->

    <hkyModel id="trueHKY">
        <frequencies>
            <frequencyModel dataType="nucleotide" id="trueFreqModel">
                <frequencies>
                    <parameter value="0.3 0.2 0.2 0.3"/>
                </frequencies>
            </frequencyModel>
        </frequencies>
        <kappa>
            <parameter value="4.0"/>
        </kappa>
    </hkyModel>

    <siteModel id="trueSiteModel">
        <substitutionModel>
            <hkyModel idref="trueHKY"/>
        </substitutionModel>
        <mutationRate>
            <parameter value="0.01"/>
        </mutationRate>
        <gammaShape gammaCategories="4">
            <parameter value="0.5"/>
        </gammaShape>
        <proportionInvariant>
            <parameter value="0.1"/>
        </proportionInvariant>
    </siteModel>

    <beagleSequenceSimulator id="simulatedAlignment" output="XML">
        <partition from="1" to="1000" every="1">
            <treeModel idref="simTreeModel"/>
            <hkyModel idref="trueHKY"/>
            <siteModel idref="trueSiteModel"/>
            <frequencyModel idref="trueFreqModel"/>
        </partition>
    </beagleSequenceSimulator>

<!--    <report>-->
<!--        Simulated alignment:-->
<!--        <beagleSequenceSimulator idref="simulatedAlignment"/>-->
<!--    </report>-->

    <patterns id="patterns">
        <beagleSequenceSimulator idref="simulatedAlignment"/>
    </patterns>

    <!-- ================================================================== -->
    <!-- Step 3: Set up inference                                            -->
    <!-- ================================================================== -->

    <!-- Random starting tree -->
    <constantSize id="initialDemo" units="substitutions">
        <populationSize>
            <parameter id="initialDemo.popSize" value="1.0"/>
        </populationSize>
    </constantSize>

    <coalescentTree id="startingTree" rootHeight="15.0">
        <beagleSequenceSimulator idref="simulatedAlignment"/>
        <constantSize idref="initialDemo"/>
    </coalescentTree>

<!--    <upgmaTree id="startingTree">-->
<!--        <distanceMatrix correction="JC">-->
<!--            <patterns>-->
<!--                <alignment idref="simulatedAlignment"/>-->
<!--            </patterns>-->
<!--        </distanceMatrix>-->
<!--    </upgmaTree>-->

    <treeModel id="treeModel">
        <coalescentTree idref="startingTree"/>
        <rootHeight>
            <parameter id="treeModel.rootHeight"/>
        </rootHeight>
        <nodeHeights internalNodes="true">
            <parameter id="treeModel.internalNodeHeights"/>
        </nodeHeights>
        <nodeHeights internalNodes="true" rootNode="true">
            <parameter id="treeModel.allInternalNodeHeights"/>
        </nodeHeights>
    </treeModel>

    <!-- ================================================================== -->
    <!-- Substitution model (estimated kappa and frequencies)                -->
    <!-- ================================================================== -->

    <hkyModel id="hky">
        <frequencies>
            <frequencyModel dataType="nucleotide" id="freqModel">
                <frequencies>
                    <parameter id="frequencies" value="0.25 0.25 0.25 0.25"/>
                </frequencies>
            </frequencyModel>
        </frequencies>
        <kappa>
            <parameter id="kappa" value="3.5" lower="1.0E-8"/>
        </kappa>
    </hkyModel>

    <!-- Site model: gamma (4 categories) + invariant sites -->
    <siteModel id="siteModel">
        <substitutionModel>
            <hkyModel idref="hky"/>
        </substitutionModel>
        <gammaShape gammaCategories="4">
            <parameter id="siteModel.alpha" value="0.5" lower="0.0"/>
        </gammaShape>
        <proportionInvariant>
            <parameter id="siteModel.pInv" value="0.1" lower="0.0" upper="1.0"/>
        </proportionInvariant>
    </siteModel>

    <!-- Strict clock (rate fixed at true value) -->
    <strictClockBranchRates id="branchRates">
        <rate>
            <parameter id="clock.rate" value="0.01"/>
        </rate>
    </strictClockBranchRates>

    <!-- Tree likelihood -->
    <treeLikelihood id="treeLikelihood" useAmbiguities="false">
        <patterns idref="patterns"/>
        <treeModel idref="treeModel"/>
        <siteModel idref="siteModel"/>
        <strictClockBranchRates idref="branchRates"/>
    </treeLikelihood>

    <!-- ================================================================== -->
    <!-- Tree prior: TABD PDE (birthScale, deathScale, birthShape estimated) -->
    <!-- Epoch times fixed at true values. Starting values near truth.       -->
    <!-- ================================================================== -->

    <ageDependentBirthDeathPDEModel id="tabd" symmetric="true" timeSteps="200" ageSteps="50" originTime="18.0">
        <treeModel idref="treeModel"/>
        <epochTimes><parameter value="5.0"/></epochTimes>
        <birthScale><parameter id="birthScale" value="0.25 0.15" lower="0.001"/></birthScale>
        <birthShape>
            <compoundParameter id="birthShape">
                <parameter id="birthShape.b" value="4.0" lower="0.0"/>
                <parameter id="birthShape.gamma" value="0.8"/>
            </compoundParameter>
        </birthShape>
        <deathScale><parameter id="deathScale" value="0.08 0.04" lower="0.001"/></deathScale>
        <deathShape>
            <compoundParameter id="deathShape">
                <parameter id="deathShape.b" value="0.0"/>
                <parameter id="deathShape.gamma" value="0.0"/>
            </compoundParameter>
        </deathShape>
    </ageDependentBirthDeathPDEModel>

    <!-- ================================================================== -->
    <!-- Operators: tree + substitution model + BD scale params              -->
    <!-- ================================================================== -->

    <operators id="operators" optimizationSchedule="log">

        <!-- Tree topology operators -->
        <subtreeSlide size="1.0" gaussian="true" weight="15">
            <treeModel idref="treeModel"/>
        </subtreeSlide>
        <narrowExchange weight="15">
            <treeModel idref="treeModel"/>
        </narrowExchange>
        <wideExchange weight="3">
            <treeModel idref="treeModel"/>
        </wideExchange>
        <wilsonBalding weight="3">
            <treeModel idref="treeModel"/>
        </wilsonBalding>

        <!-- Tree height operators -->
        <scaleOperator scaleFactor="0.75" weight="3">
            <parameter idref="treeModel.rootHeight"/>
        </scaleOperator>
        <uniformOperator weight="30">
            <parameter idref="treeModel.internalNodeHeights"/>
        </uniformOperator>

        <!-- Substitution model operators -->
        <scaleOperator scaleFactor="0.75" weight="1">
            <parameter idref="kappa"/>
        </scaleOperator>
        <deltaExchange delta="0.01" weight="1">
            <parameter idref="frequencies"/>
        </deltaExchange>

        <!-- Site model operators -->
        <scaleOperator scaleFactor="0.75" weight="1">
            <parameter idref="siteModel.alpha"/>
        </scaleOperator>
        <randomWalkOperator windowSize="0.05" weight="1">
            <parameter idref="siteModel.pInv"/>
        </randomWalkOperator>

        <!-- Birth-death scale operators -->
        <scaleOperator scaleFactor="0.85" weight="2">
            <parameter idref="birthScale"/>
        </scaleOperator>
        <scaleOperator scaleFactor="0.85" weight="3" scaleAll="true">
            <parameter idref="birthScale"/>
        </scaleOperator>
        <scaleOperator scaleFactor="0.85" weight="2">
            <parameter idref="deathScale"/>
        </scaleOperator>

        <!-- Birth shape operators -->
        <scaleOperator scaleFactor="0.85" weight="2">
            <parameter idref="birthShape.b"/>
        </scaleOperator>
        <randomWalkOperator windowSize="0.2" weight="2">
            <parameter idref="birthShape.gamma"/>
        </randomWalkOperator>

    </operators>

    <!-- ================================================================== -->
    <!-- MCMC                                                                -->
    <!-- ================================================================== -->

    <mcmc id="mcmc" chainLength="5000000" autoOptimize="true">
        <posterior id="posterior">
            <prior id="prior">
                <ageDependentBirthDeathPDEModel idref="tabd"/>
                <logNormalPrior mean="1.0" stdev="1.25" offset="0.0" meanInRealSpace="true">
                    <parameter idref="kappa"/>
                </logNormalPrior>
                <exponentialPrior mean="1.0" offset="0.0">
                    <parameter idref="siteModel.alpha"/>
                </exponentialPrior>
                <uniformPrior lower="0.0" upper="1.0">
                    <parameter idref="siteModel.pInv"/>
                </uniformPrior>
                <logNormalPrior mean="0.0" stdev="1.0" offset="0.0" meanInRealSpace="false">
                    <parameter idref="birthScale"/>
                </logNormalPrior>
                <logNormalPrior mean="0.0" stdev="1.0" offset="0.0" meanInRealSpace="false">
                    <parameter idref="deathScale"/>
                </logNormalPrior>
                <exponentialPrior mean="10.0" offset="0.0">
                    <parameter idref="birthShape.b"/>
                </exponentialPrior>
                <normalPrior mean="0.0" stdev="5.0">
                    <parameter idref="birthShape.gamma"/>
                </normalPrior>
            </prior>
            <likelihood id="likelihood">
                <treeLikelihood idref="treeLikelihood"/>
            </likelihood>
        </posterior>
        <operators idref="operators"/>

        <!-- Screen log -->
        <log logEvery="10000">
            <column label="Posterior" dp="4" width="12">
                <posterior idref="posterior"/>
            </column>
            <column label="Prior" dp="4" width="12">
                <prior idref="prior"/>
            </column>
            <column label="Likelihood" dp="4" width="12">
                <likelihood idref="likelihood"/>
            </column>
            <column label="rootHeight" sf="6" width="12">
                <parameter idref="treeModel.rootHeight"/>
            </column>
            <column label="kappa" sf="4" width="8">
                <parameter idref="kappa"/>
            </column>
            <column label="alpha" sf="4" width="8">
                <parameter idref="siteModel.alpha"/>
            </column>
            <column label="pInv" sf="4" width="8">
                <parameter idref="siteModel.pInv"/>
            </column>
            <column label="TABD" dp="4" width="12">
                <ageDependentBirthDeathPDEModel idref="tabd"/>
            </column>
            <column label="bScale" sf="4" width="10">
                <parameter idref="birthScale"/>
            </column>
            <column label="dScale" sf="4" width="10">
                <parameter idref="deathScale"/>
            </column>
            <column label="bShape.b" sf="4" width="10">
                <parameter idref="birthShape.b"/>
            </column>
            <column label="bShape.g" sf="4" width="10">
                <parameter idref="birthShape.gamma"/>
            </column>
        </log>

        <!-- File log -->
        <log id="fileLog" logEvery="1000" fileName="simple_seqSim_treeInference5.log" overwrite="true">
            <posterior idref="posterior"/>
            <prior idref="prior"/>
            <likelihood idref="likelihood"/>
            <treeLikelihood idref="treeLikelihood"/>
            <ageDependentBirthDeathPDEModel idref="tabd"/>
            <parameter idref="treeModel.rootHeight"/>
            <parameter idref="kappa"/>
            <parameter idref="frequencies"/>
            <parameter idref="siteModel.alpha"/>
            <parameter idref="siteModel.pInv"/>
            <parameter idref="birthScale"/>
            <parameter idref="deathScale"/>
            <parameter idref="birthShape.b"/>
            <parameter idref="birthShape.gamma"/>
        </log>

        <!-- Tree log -->
        <logTree id="treeFileLog" logEvery="1000" nexusFormat="true"
                 fileName="simple_seqSim_treeInference5.trees"
                 sortTranslationTable="true" overwrite="true">
            <treeModel idref="treeModel"/>
            <strictClockBranchRates idref="branchRates"/>
            <posterior idref="posterior"/>
        </logTree>
    </mcmc>

    <report>
        <property name="timer">
            <mcmc idref="mcmc"/>
        </property>
    </report>

    <traceAnalysis fileName="simple_seqSim_treeInference5.log" burnIn="1000000"/>

</beast>